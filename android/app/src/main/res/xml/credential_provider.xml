<?xml version="1.0" encoding="utf-8"?>
<!--
    Capability advertisement for the Android 14+ Credential Manager.
    Declares which credential types this provider can fill / save.
    Only TYPE_PASSWORD_CREDENTIAL for now — passkey support would add
    `android.credentials.TYPE_PUBLIC_KEY_CREDENTIAL` once we wire up
    the WebAuthn signing flow.
-->
<credential-provider xmlns:android="http://schemas.android.com/apk/res/android">
    <capabilities>
        <capability name="android.credentials.TYPE_PASSWORD_CREDENTIAL" />
    </capabilities>
</credential-provider>
