<?xml version="1.0" encoding="utf-8"?>
<!--
    Lock glyph — same silhouette as the Linux GUI / packaging icon
    (packaging/passwort-manager.svg). Re-mapped onto the Android
    adaptive-icon 108x108 viewport so the lock sits inside the
    66dp safe zone all launcher masks (circle, squircle, rounded
    square) preserve.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <!-- Shackle (the U on top) -->
    <path
        android:pathData="M42,52.2 V41.4 a12,12 0 0 1 24,0 V52.2"
        android:strokeColor="#B59CFF"
        android:strokeWidth="4.8"
        android:strokeLineCap="round"
        android:fillColor="#00000000" />
    <!-- Lock body -->
    <path
        android:pathData="M36,50.4 h36 a4.8,4.8 0 0 1 4.8,4.8 v22 a4.8,4.8 0 0 1 -4.8,4.8 h-36 a4.8,4.8 0 0 1 -4.8,-4.8 v-22 a4.8,4.8 0 0 1 4.8,-4.8 z"
        android:fillColor="#B59CFF" />
    <!-- Keyhole — circle + stem -->
    <path
        android:pathData="M54,63 m-3.6,0 a3.6,3.6 0 1,0 7.2,0 a3.6,3.6 0 1,0 -7.2,0"
        android:fillColor="#1E1E22" />
    <path
        android:pathData="M52.2,63 h3.6 v8.4 a1.2,1.2 0 0 1 -1.2,1.2 h-1.2 a1.2,1.2 0 0 1 -1.2,-1.2 v-8.4 z"
        android:fillColor="#1E1E22" />
</vector>
