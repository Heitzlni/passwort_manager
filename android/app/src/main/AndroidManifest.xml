<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Required only for the optional HIBP audit screen. We make one
         outbound HTTPS request per audited entry, sending the first 5
         hex chars of the SHA-1 of each password — never the password
         itself. See HibpClient.kt + AuditScreen.kt. -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Required by the accessibility-fill fallback so we can post the
         "tap to fill" / "save credential?" notifications. Runtime-
         requested on Android 13+. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:name=".PasswortApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Passwort_Manager">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.Passwort_Manager">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!-- Triggered by the app shortcut (long-press the launcher
                 icon) AND by the Quick Settings tile. Routes straight
                 into the Add Entry form after unlock. -->
            <intent-filter>
                <action android:name="com.example.passwort_manager.ACTION_ADD_ENTRY" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
            <!-- Static app shortcuts for the launcher long-press menu. -->
            <meta-data
                android:name="android.app.shortcuts"
                android:resource="@xml/shortcuts" />
        </activity>

        <!-- Accessibility fallback autofill — the same approach
             Bitwarden / 1Password use when the Autofill Framework
             can't see an app's fields. User has to enable it under
             Settings → Accessibility → Installed services and
             confirm the scary system warning.

             FillTriggerActivity is a transparent shim that the
             accessibility "tap to fill" notification opens; it
             calls into the running service to inject text via
             ACTION_SET_TEXT and finishes immediately. -->
        <service
            android:name=".PasswortAccessibilityService"
            android:exported="true"
            android:label="@string/app_name"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config" />
        </service>

        <activity
            android:name=".FillTriggerActivity"
            android:exported="false"
            android:excludeFromRecents="true"
            android:theme="@android:style/Theme.Translucent.NoTitleBar" />

        <!-- Receives notification taps from PasswortAccessibilityService
             to queue a fill request without bouncing through a
             transparent Activity. Skipping the Activity transition
             keeps the target app (Discord etc.) in the foreground the
             whole time, so the fill feels instant. -->
        <receiver
            android:name=".FillBroadcastReceiver"
            android:exported="false" />

        <!-- Quick Settings tile users can pin to their notification
             shade for one-tap "save credential" access. Always works
             regardless of which app they were in. -->
        <service
            android:name=".QuickSaveTileService"
            android:exported="true"
            android:icon="@drawable/ic_lock_status"
            android:label="@string/tile_quick_save"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>

        <!-- Companion to QuickSaveTileService: "Fill credential" — opens
             our app in pick-to-fill mode so the user can inject any
             saved credential into the form they had open underneath. -->
        <service
            android:name=".QuickFillTileService"
            android:exported="true"
            android:icon="@drawable/ic_lock_status"
            android:label="@string/tile_quick_fill"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>

        <!--
            Spawned by Android when our autofill service replies with an
            authentication-required dataset (vault was locked at the time
            of the fill request). Not directly launchable from elsewhere.
        -->
        <activity
            android:name=".AutofillActivity"
            android:exported="false"
            android:theme="@style/Theme.Passwort_Manager"
            android:excludeFromRecents="true" />

        <!-- Launched from PasswortAutofillService.onSaveRequest, the
             accessibility-fill service, or Credential Manager when the
             user submits a login form. Lives in its own task (empty
             taskAffinity) so finishAndRemoveTask() returns the user
             to the app they were logging into rather than uncovering
             MainActivity in the manager's task. -->
        <activity
            android:name=".SaveActivity"
            android:exported="false"
            android:theme="@style/Theme.Passwort_Manager"
            android:excludeFromRecents="true"
            android:taskAffinity=""
            android:launchMode="singleTask" />

        <!--
            The autofill service itself. Requires BIND_AUTOFILL_SERVICE so
            only the system can connect to us, and a meta-data resource
            pointing at our service config (capabilities + settings hook).
            Users still have to enable it manually under
            Einstellungen → Passwörter & Konten → Bevorzugter Dienst
            (the system never auto-enables third-party autofill).
        -->
        <service
            android:name=".PasswortAutofillService"
            android:exported="true"
            android:label="@string/app_name"
            android:permission="android.permission.BIND_AUTOFILL_SERVICE">
            <intent-filter>
                <action android:name="android.service.autofill.AutofillService" />
            </intent-filter>
            <meta-data
                android:name="android.autofill"
                android:resource="@xml/autofill_service" />
        </service>

        <!--
            Android 14+ Credential Manager provider. Used by modern apps
            (Discord, Google services, Material-3 apps) that prefer the
            unified credentials API over legacy AutofillManager.
            Capabilities advertised in res/xml/credential_provider.xml.

            Users enable our app under:
              Einstellungen → Passwörter, Passkeys und Konten → Anbieter
        -->
        <service
            android:name=".PasswortCredentialProviderService"
            android:exported="true"
            android:label="@string/app_name"
            android:permission="android.permission.BIND_CREDENTIAL_PROVIDER_SERVICE">
            <intent-filter>
                <action android:name="android.service.credentials.CredentialProviderService" />
            </intent-filter>
            <meta-data
                android:name="android.credentials.provider"
                android:resource="@xml/credential_provider" />
        </service>

        <!-- Backing activity for credential-fill entries — opens when
             the user taps one of our credential rows in the system
             picker. Returns the (username, password) via
             PendingIntentHandler.setGetCredentialResponse. -->
        <activity
            android:name=".CredentialFillActivity"
            android:exported="false"
            android:theme="@style/Theme.Passwort_Manager"
            android:excludeFromRecents="true" />
    </application>

</manifest>